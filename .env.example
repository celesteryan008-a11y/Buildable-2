# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# NextAuth requires a secret to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The canonical URL of your deployed app (no trailing slash).
# Locally: http://localhost:3000
# On Vercel: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Optional: comma-separated allowlist of Google emails permitted to sign in.
# Leave unset to allow any Google account to sign in.
# ALLOWED_EMAILS=you@example.com,friend@example.com

# Optional: max generations per signed-in user per 24h (default 30)
# DAILY_GENERATION_LIMIT=30
